#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
service_name="${CCO_SERVICE_NAME:-cco}"
host="${CCO_SERVICE_HOST:-127.0.0.1}"
port="${CCO_SERVICE_PORT:-8765}"
unit_dir="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
unit_path="${unit_dir}/${service_name}.service"

mkdir -p "$unit_dir"

cat >"$unit_path" <<EOF
[Unit]
Description=Codex Claude Orchestrator host service
After=default.target

[Service]
Type=simple
WorkingDirectory=${repo_root}
ExecStart=/bin/bash ${repo_root}/scripts/cco-base server --host ${host} --port ${port}
Restart=always
RestartSec=2

[Install]
WantedBy=default.target
EOF

systemctl --user daemon-reload
systemctl --user enable --now "${service_name}.service"

echo "Installed ${unit_path}"
echo "Service started: systemctl --user status ${service_name}.service"
echo "Health check: curl -s http://${host}:${port}/health"
